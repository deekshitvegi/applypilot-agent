{
  "manifest_version": 3,
  "name": "ApplyPilot",
  "description": "Local-first job application copilot",
  "version": "0.5.1",
  "permissions": ["activeTab", "sidePanel", "storage", "scripting", "tabs"],
  "host_permissions": ["http://127.0.0.1:8765/*"],
  "optional_host_permissions": ["https://*/*", "http://*/*"],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "Open ApplyPilot"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html"
}
